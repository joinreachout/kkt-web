---
import '~/styles/global.css';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import VersionBadge from '~/components/VersionBadge.astro';
import AdvisorMount from '~/components/AdvisorMount.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
  ogImage?: string;
  pageType?: 'website' | 'article';
  articleAuthor?: string;
  articlePublished?: string; // ISO date
}

const {
  title = 'KKT — AI that ships, not slides.',
  description = 'Senior PMO + AI delivery for mid-sized retailers and fuel networks. Tallinn, EU.',
  canonical,
  noindex = false,
  ogImage = '/og/home.png',
  pageType = 'website',
  articleAuthor,
  articlePublished,
} = Astro.props as Props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';

// Schema.org JSON-LD. Always emits an Organization graph node + a
// page-type node (WebPage / Article). Search engines pick from the
// graph; we keep both nodes lightweight and accurate.
const schemaGraph: Record<string, unknown>[] = [
  {
    '@type': 'Organization',
    '@id': 'https://kittykat.tech/#org',
    name: 'Kitty Kat Technologies',
    alternateName: 'KKT',
    url: 'https://kittykat.tech/',
    logo: 'https://kittykat.tech/favicon.svg',
    email: 'hello@kittykat.tech',
    telephone: '+372 5555 3621',
    sameAs: [
      'https://www.linkedin.com/company/kittykattech/',
    ],
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Jõe 7',
      postalCode: '10151',
      addressLocality: 'Tallinn',
      addressCountry: 'EE',
    },
    description:
      'Senior PMO + AI delivery for mid-sized retailers and fuel networks. Tallinn, EU.',
    foundingLocation: 'Tallinn, Estonia',
    knowsAbout: ['AI delivery', 'PMO', 'Fuel retail', 'Retail analytics'],
  },
];

if (pageType === 'article') {
  schemaGraph.push({
    '@type': 'Article',
    headline: title,
    description,
    image: ogImageUrl,
    url: canonicalUrl,
    author: articleAuthor
      ? { '@type': 'Person', name: articleAuthor }
      : { '@id': 'https://kittykat.tech/#org' },
    publisher: { '@id': 'https://kittykat.tech/#org' },
    datePublished: articlePublished,
    dateModified: articlePublished,
    mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  });
} else {
  schemaGraph.push({
    '@type': 'WebPage',
    '@id': canonicalUrl,
    name: title,
    description,
    url: canonicalUrl,
    isPartOf: { '@id': 'https://kittykat.tech/#org' },
    primaryImageOfPage: { '@type': 'ImageObject', url: ogImageUrl },
  });
  if (isHome) {
    // Home page acts as the WebSite root; declare it once.
    schemaGraph.push({
      '@type': 'WebSite',
      '@id': 'https://kittykat.tech/#website',
      url: 'https://kittykat.tech/',
      name: 'KKT — AI that ships, not slides.',
      publisher: { '@id': 'https://kittykat.tech/#org' },
    });
  }
}

const schemaJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': schemaGraph,
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="KKT" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Fonts: DM Sans + Playfair Display, matching retail microsite -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="KKT — Insights" href="/rss.xml" />

    <script type="application/ld+json" set:html={schemaJsonLd}></script>
  </head>

  <body>
    <a href="#main" class="skip-link">Skip to content</a>

    <Header />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <AdvisorMount />
    <VersionBadge />
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: -9999px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .skip-link:focus {
    left: 16px;
    top: 12px;
    width: auto;
    height: auto;
    padding: 8px 12px;
    background: var(--text-primary);
    color: #fff;
    z-index: 100;
    border-radius: 3px;
    font-size: 13px;
  }
</style>
