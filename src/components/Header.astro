---
// KKT wordmark + nav. Sticky top bar.
import CatMark from './CatMark.astro';
const navItems = [
  { href: '/industries/retail', label: 'Retail' },
  { href: '/industries/fuel-retail', label: 'Fuel retail' },
  { href: '/case-studies/', label: 'Case studies' },
  { href: '/approach', label: 'Approach' },
  { href: '/about', label: 'About' },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="wordmark" aria-label="KKT — home">
      <CatMark size={26} />
      <span class="wordmark-text">KKT</span>
    </a>

    <nav aria-label="Primary">
      <ul class="nav-list">
        {navItems.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="header-actions">
      <button type="button" class="advisor-trigger advisor-trigger-full" data-advisor-open aria-label="Open advisor (Cmd+K)">
        <span class="advisor-trigger-label">Ask the advisor</span>
        <span class="kbd-chip"><kbd>⌘</kbd><kbd>K</kbd></span>
      </button>
      <button type="button" class="advisor-trigger advisor-trigger-icon" data-advisor-open aria-label="Open advisor">
        <span aria-hidden="true">✦</span>
      </button>
      <a href="/contact" class="header-cta">Book a diagnostic</a>
      <button type="button" class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav">
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
      </button>
    </div>
  </div>

  <div id="mobile-nav" class="mobile-nav" hidden>
    <ul>
      {navItems.map((item) => (
        <li><a href={item.href}>{item.label}</a></li>
      ))}
      <li class="mobile-nav-cta"><a href="/contact">Book a diagnostic</a></li>
    </ul>
  </div>
</header>

<script>
  // Mobile nav toggle — vanilla, no framework. Just expand/collapse the
  // hidden #mobile-nav drawer when the hamburger button is clicked.
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const drawer = document.getElementById('mobile-nav');
  if (toggle && drawer) {
    const close = () => {
      toggle.setAttribute('aria-expanded', 'false');
      drawer.hidden = true;
      toggle.classList.remove('is-open');
    };
    const open = () => {
      toggle.setAttribute('aria-expanded', 'true');
      drawer.hidden = false;
      toggle.classList.add('is-open');
    };
    toggle.addEventListener('click', () => {
      if (drawer.hidden) open();
      else close();
    });
    // Close after navigation (anchor click inside drawer)
    drawer.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
    // Close on Esc
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !drawer.hidden) close();
    });
  }
</script>

<script>
  // Open the advisor panel from any button[data-advisor-open] on the page.
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement | null;
    if (!target) return;
    const trigger = target.closest('[data-advisor-open]');
    if (!trigger) return;
    e.preventDefault();
    const prefill = (trigger as HTMLElement).dataset.advisorPrefill;
    window.dispatchEvent(
      new CustomEvent('kkt:advisor:open', {
        detail: prefill ? { prefill } : undefined,
      }),
    );
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    height: 58px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--text-primary);
    text-decoration: none;
  }
  .wordmark:hover { text-decoration: none; color: var(--text-primary); }
  .wordmark-text {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .nav-list {
    display: none;
    list-style: none;
    gap: 28px;
    margin: 0;
    padding: 0;
  }
  .nav-list a {
    font-size: 13px;
    color: var(--text-secondary);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color .15s ease;
  }
  .nav-list a:hover { color: var(--text-primary); }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .advisor-trigger {
    display: none;
    align-items: center;
    gap: 8px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 7px 12px;
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--text-secondary);
    cursor: pointer;
    transition: border-color .15s ease, color .15s ease, background .15s ease;
  }
  .advisor-trigger:hover {
    border-color: var(--accent);
    color: var(--text-primary);
  }
  .advisor-trigger-icon {
    width: 36px;
    height: 36px;
    padding: 0;
    justify-content: center;
    font-size: 16px;
    color: var(--accent-text);
  }
  .advisor-trigger-icon:hover {
    color: var(--accent);
    background: var(--accent-dim);
  }
  .kbd-chip {
    display: inline-flex;
    gap: 2px;
  }
  .kbd-chip kbd {
    font-family: var(--font-mono);
    font-size: 10px;
    background: var(--surface-alt);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 1px 4px;
    color: var(--text-secondary);
    line-height: 1;
  }

  .header-cta {
    display: none;
    font-size: 13px;
    padding: 8px 16px;
    background: var(--text-primary);
    color: #FFF;
    border-radius: 3px;
    text-decoration: none;
    font-weight: 600;
    letter-spacing: 0.02em;
    transition: opacity .15s ease;
  }
  .header-cta:hover { opacity: 0.85; text-decoration: none; }

  /* Mobile-first: show icon-only advisor trigger + hamburger so it's always reachable */
  .advisor-trigger-icon { display: inline-flex; }

  .nav-toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 36px;
    height: 36px;
    padding: 0;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 3px;
    cursor: pointer;
    align-items: center;
    transition: border-color .15s ease;
  }
  .nav-toggle:hover { border-color: var(--border-hover); }
  .nav-toggle-bar {
    display: block;
    width: 16px;
    height: 1.5px;
    background: var(--text-primary);
    transition: transform .18s ease, opacity .18s ease;
  }
  .nav-toggle.is-open .nav-toggle-bar:nth-child(1) {
    transform: translateY(5.5px) rotate(45deg);
  }
  .nav-toggle.is-open .nav-toggle-bar:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle.is-open .nav-toggle-bar:nth-child(3) {
    transform: translateY(-5.5px) rotate(-45deg);
  }

  .mobile-nav {
    border-top: 1px solid var(--border);
    background: var(--surface);
  }
  .mobile-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 8px clamp(20px, 4vw, 48px);
  }
  .mobile-nav li {
    border-bottom: 1px solid var(--border);
  }
  .mobile-nav li:last-child { border-bottom: none; }
  .mobile-nav a {
    display: block;
    padding: 14px 0;
    font-size: 15px;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
  }
  .mobile-nav a:hover { color: var(--accent-text); }
  .mobile-nav-cta a {
    color: var(--accent-text);
    font-weight: 600;
  }

  @media (min-width: 880px) {
    .nav-list { display: flex; }
    .advisor-trigger-full { display: inline-flex; }
    .advisor-trigger-icon { display: none; }
    .header-cta { display: inline-flex; align-items: center; }
    .nav-toggle { display: none; }
    .mobile-nav { display: none !important; }
  }
</style>
