---
// KKT wordmark + nav. Sticky top bar.
import CatMark from './CatMark.astro';
const navItems = [
  { href: '/industries/retail', label: 'Retail' },
  { href: '/industries/fuel-retail', label: 'Fuel retail' },
  { href: '/case-studies/', label: 'Case studies' },
  { href: '/approach', label: 'Approach' },
  { href: '/about', label: 'About' },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="wordmark" aria-label="KKT — home">
      <CatMark size={26} />
      <span class="wordmark-text">KKT</span>
    </a>

    <nav aria-label="Primary">
      <ul class="nav-list">
        {navItems.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="header-actions">
      <button type="button" class="advisor-trigger" data-advisor-open aria-label="Open advisor (Cmd+K)">
        <span>Ask the advisor</span>
        <span class="kbd-chip"><kbd>⌘</kbd><kbd>K</kbd></span>
      </button>
      <a href="/contact" class="header-cta">Book a diagnostic</a>
    </div>
  </div>
</header>

<script>
  // Open the advisor panel from any button[data-advisor-open] on the page.
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement | null;
    if (!target) return;
    const trigger = target.closest('[data-advisor-open]');
    if (!trigger) return;
    e.preventDefault();
    const prefill = (trigger as HTMLElement).dataset.advisorPrefill;
    window.dispatchEvent(
      new CustomEvent('kkt:advisor:open', {
        detail: prefill ? { prefill } : undefined,
      }),
    );
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    height: 58px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--text-primary);
    text-decoration: none;
  }
  .wordmark:hover { text-decoration: none; color: var(--text-primary); }
  .wordmark-text {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .nav-list {
    display: none;
    list-style: none;
    gap: 28px;
    margin: 0;
    padding: 0;
  }
  .nav-list a {
    font-size: 13px;
    color: var(--text-secondary);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color .15s ease;
  }
  .nav-list a:hover { color: var(--text-primary); }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .advisor-trigger {
    display: none;
    align-items: center;
    gap: 8px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 7px 12px;
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--text-secondary);
    cursor: pointer;
    transition: border-color .15s ease, color .15s ease;
  }
  .advisor-trigger:hover {
    border-color: var(--border-hover);
    color: var(--text-primary);
  }
  .kbd-chip {
    display: inline-flex;
    gap: 2px;
  }
  .kbd-chip kbd {
    font-family: var(--font-mono);
    font-size: 10px;
    background: var(--surface-alt);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 1px 4px;
    color: var(--text-secondary);
    line-height: 1;
  }

  .header-cta {
    display: none;
    font-size: 13px;
    padding: 8px 16px;
    background: var(--text-primary);
    color: #FFF;
    border-radius: 3px;
    text-decoration: none;
    font-weight: 600;
    letter-spacing: 0.02em;
    transition: opacity .15s ease;
  }
  .header-cta:hover { opacity: 0.85; text-decoration: none; }

  @media (min-width: 880px) {
    .nav-list { display: flex; }
    .advisor-trigger { display: inline-flex; }
    .header-cta { display: inline-flex; align-items: center; }
  }
  @media (min-width: 720px) and (max-width: 879px) {
    .advisor-trigger { display: inline-flex; }
  }
</style>
