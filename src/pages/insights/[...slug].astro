---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('insights');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} — KKT Insights`}
  description={post.data.summary}
  pageType="article"
  articleAuthor={post.data.author}
  articlePublished={post.data.publishedAt}
>
  <article class="prose-page">
    <div class="container narrow">
      <div class="section-label">Insights</div>
      <h1 class="h1-page">{post.data.title}</h1>
      <div class="post-meta">
        <span>{post.data.author}</span>
        <span class="sep">·</span>
        <time datetime={post.data.publishedAt}>
          {new Date(post.data.publishedAt).toLocaleDateString('en-GB', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
      </div>

      <div class="prose">
        <Content />
      </div>

      <p class="back">
        <a href="/insights">← All insights</a>
      </p>
    </div>
  </article>
</BaseLayout>

<style>
  .prose-page { padding-top: clamp(40px, 6vh, 72px); padding-bottom: clamp(56px, 9vh, 96px); }
  .narrow { max-width: 720px; }
  .section-label { margin-bottom: 18px; }
  .h1-page {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1.18;
    margin-bottom: 14px;
    letter-spacing: -0.01em;
  }
  .post-meta {
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 36px;
  }
  .post-meta .sep { margin: 0 8px; }
  .prose :global(h2) {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 20px;
    color: var(--text-primary);
    margin-top: 36px;
    margin-bottom: 12px;
  }
  .prose :global(p) { margin-bottom: 14px; }
  .prose :global(a) { color: var(--text-primary); }
  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 14px 1.4em;
  }
  .prose :global(li) { margin-bottom: 6px; }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 13px;
    background: var(--surface-alt);
    padding: 1px 6px;
    border-radius: 3px;
  }
  .back { margin-top: 48px; }
  .back a { font-size: 14px; color: var(--text-secondary); }
</style>
