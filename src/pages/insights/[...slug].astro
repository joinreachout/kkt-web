---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('insights');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} — KKT Insights`}
  description={post.data.summary}
  pageType="article"
  articleAuthor={post.data.author}
  articlePublished={post.data.publishedAt}
>
  <article class="prose-page">
    <div class="container narrow">
      <div class="section-label">Insights — Working in Public</div>
      <h1 class="h1-page">{post.data.title}</h1>
      {post.data.summary && (
        <p class="post-summary">{post.data.summary}</p>
      )}
      <div class="post-meta">
        <span class="post-author">{post.data.author}</span>
        <span class="sep">·</span>
        <time datetime={post.data.publishedAt}>
          {new Date(post.data.publishedAt).toLocaleDateString('en-GB', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
      </div>

      <hr class="post-rule" />

      <div class="prose">
        <Content />
      </div>

      <footer class="post-foot">
        <p class="back">
          <a href="/insights">← All insights</a>
        </p>
        <p class="rss-hint">
          Subscribe via <a href="/rss.xml">RSS</a>
          &middot;
          <button type="button" class="advisor-link" data-advisor-open>Ask the advisor</button>
        </p>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .prose-page { padding-top: clamp(40px, 6vh, 72px); padding-bottom: clamp(56px, 9vh, 96px); }
  .narrow { max-width: 720px; }
  .section-label { margin-bottom: 18px; }
  .h1-page {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1.18;
    margin-bottom: 14px;
    letter-spacing: -0.01em;
  }
  .post-summary {
    font-size: clamp(16px, 1.8vw, 19px);
    color: var(--text-secondary);
    line-height: 1.55;
    margin-bottom: 18px;
    max-width: 60ch;
  }
  .post-meta {
    font-size: 13px;
    color: var(--text-muted);
  }
  .post-author {
    color: var(--text-primary);
    font-weight: 500;
  }
  .post-meta .sep { margin: 0 8px; }
  .post-rule {
    margin: 28px 0 36px;
    border: none;
    border-top: 1px solid var(--border);
  }
  .prose :global(h2) {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 20px;
    color: var(--text-primary);
    margin-top: 36px;
    margin-bottom: 12px;
  }
  .prose :global(p) { margin-bottom: 14px; }
  .prose :global(a) { color: var(--text-primary); }
  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 14px 1.4em;
  }
  .prose :global(li) { margin-bottom: 6px; }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 13px;
    background: var(--surface-alt);
    padding: 1px 6px;
    border-radius: 3px;
  }
  .post-foot {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }
  .post-foot p { margin: 0; font-size: 14px; }
  .back a { color: var(--text-secondary); }
  .rss-hint {
    color: var(--text-muted);
    font-size: 13px;
  }
  .rss-hint a, .advisor-link {
    color: var(--text-primary);
    text-decoration: none;
    background: transparent;
    border: none;
    padding: 0;
    font: inherit;
    cursor: pointer;
  }
  .rss-hint a:hover, .advisor-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--accent);
  }
</style>
