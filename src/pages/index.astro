---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import CTA from '~/components/CTA.astro';

// Trust strip variant — flip to 'A' or 'B' if Alfa Oil consent tier shifts.
// See WORK/briefs/alfa-oil-content-brief.md.
const trustVariant = 'C' as const;
---

<BaseLayout
  title="KKT — AI that ships, not slides."
  description="Senior PMO + AI delivery for mid-sized retailers and fuel networks. Tallinn, EU."
>
  <Hero trustVariant={trustVariant} />

  <section class="section section-industries">
    <div class="container">
      <div class="section-label">Where we work</div>
      <h2 class="h2-section">Two industries. One delivery model.</h2>
      <div class="industry-grid">
        <a href="/industries/retail" class="industry-card">
          <div class="industry-eyebrow">Retail</div>
          <h3 class="industry-title">Mid-sized retailers</h3>
          <p>
            Margin, cash, customer ownership, decision speed. Where AI and PMO
            discipline earn their place against measurable outcomes.
          </p>
          <span class="industry-arrow">See the playbook →</span>
        </a>

        <a href="/industries/fuel-retail" class="industry-card">
          <div class="industry-eyebrow">Fuel retail</div>
          <h3 class="industry-title">Fuel networks</h3>
          <p>
            Optimus runs price, margin, and operations across stations. Live at
            Alfa Oil — 600+ stations, $500M revenue, in production.
          </p>
          <span class="industry-arrow">See Optimus →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="section section-featured">
    <div class="container">
      <div class="section-label">Featured case</div>
      <h2 class="h2-section">Alfa Oil — Optimus operating across the network.</h2>
      <p class="featured-body">
        Walk through the engagement: where it started, what shipped, what it
        moved. No vendor-deck claims — just what the system does in
        production today.
      </p>
      <a href="/case-studies/alfa-oil" class="btn-ghost">Read the case</a>
    </div>
  </section>

  <section class="section section-howweship">
    <div class="container">
      <div class="section-label">How we ship</div>
      <h2 class="h2-section">Delivery, not theatre.</h2>

      <div class="hws-grid">
        <div class="hws-card">
          <div class="hws-eyebrow">01 — Diagnostic</div>
          <h3 class="hws-title">A diagnostic before a programme.</h3>
          <p>
            Two weeks. Scope only. We look before we commit. Output is a
            sharp picture of what to ship, what to leave alone, what proof
            you need before you can decide.
          </p>
        </div>

        <div class="hws-card">
          <div class="hws-eyebrow">02 — Discipline</div>
          <h3 class="hws-title">PMO discipline as load-bearing.</h3>
          <p>
            Scope, sequencing, ownership, shipping under constraint. PMO
            is what separates a slide-led project from one that runs in
            production.
          </p>
        </div>

        <div class="hws-card">
          <div class="hws-eyebrow">03 — Earned place</div>
          <h3 class="hws-title">AI where it earns its place.</h3>
          <p>
            No AI for AI's sake. Margin, cash, availability, customer
            value, productivity — the outcome sets the bar before the tool
            does.
          </p>
        </div>

        <div class="hws-card">
          <div class="hws-eyebrow">04 — Exit</div>
          <h3 class="hws-title">Until the system runs without us.</h3>
          <p>
            Engagements end; the product keeps operating. We design for
            that exit from the first week. Internal counterparts inherit
            the system, not the dependency.
          </p>
        </div>
      </div>

      <p class="hws-tail">
        <a href="/approach" class="hws-link">How an engagement actually runs →</a>
      </p>
    </div>
  </section>

  <CTA />
</BaseLayout>

<style>
  .section-industries {
    padding-top: clamp(48px, 7vh, 80px);
    padding-bottom: clamp(48px, 7vh, 80px);
    border-top: 1px solid var(--border);
  }
  .section-industries .section-label,
  .section-featured .section-label {
    margin-bottom: 12px;
  }
  .section-industries h2 {
    margin-bottom: 36px;
    max-width: 22ch;
  }

  .industry-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }
  @media (min-width: 720px) {
    .industry-grid {
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
  }

  .industry-card {
    display: block;
    padding: 28px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    text-decoration: none;
    transition: border-color .18s ease, transform .18s ease;
    color: inherit;
  }
  .industry-card:hover {
    border-color: var(--border-hover);
    text-decoration: none;
  }
  .industry-eyebrow {
    font-size: 11px;
    color: var(--accent-text);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .industry-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 24px;
    color: var(--text-primary);
    margin-bottom: 10px;
    font-weight: 400;
  }
  .industry-card p {
    font-size: 15px;
    color: var(--text-secondary);
    margin-bottom: 16px;
  }
  .industry-arrow {
    font-size: 13px;
    color: var(--text-primary);
    font-weight: 500;
  }

  .section-featured {
    padding-top: clamp(48px, 7vh, 80px);
    padding-bottom: clamp(48px, 7vh, 80px);
    border-top: 1px solid var(--border);
  }
  .section-featured h2 {
    margin-bottom: 18px;
    max-width: 22ch;
  }
  .featured-body {
    max-width: 60ch;
    margin-bottom: 28px;
  }

  .section-howweship {
    padding-top: clamp(48px, 7vh, 80px);
    padding-bottom: clamp(48px, 7vh, 80px);
    border-top: 1px solid var(--border);
    background: var(--surface-alt);
  }
  .section-howweship .section-label { margin-bottom: 12px; }
  .section-howweship h2 { margin-bottom: 36px; max-width: 22ch; }
  .hws-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
    margin-bottom: 28px;
  }
  @media (min-width: 720px) {
    .hws-grid { grid-template-columns: 1fr 1fr; }
  }
  .hws-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 24px 26px;
  }
  .hws-eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent-text);
    font-weight: 600;
    letter-spacing: 0.06em;
    margin-bottom: 12px;
  }
  .hws-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 22px;
    color: var(--text-primary);
    margin-bottom: 10px;
    line-height: 1.2;
  }
  .hws-card p { font-size: 15px; max-width: 50ch; }
  .hws-tail { margin-top: 8px; }
  .hws-link {
    font-size: 14px;
    color: var(--text-primary);
    font-weight: 500;
    text-decoration: none;
  }
  .hws-link:hover { text-decoration: underline; text-underline-offset: 3px; text-decoration-color: var(--accent); }
</style>
