---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import CTA from '~/components/CTA.astro';
import AlfaNetworkMap from '~/components/AlfaNetworkMap.astro';

// Trust strip variant — flip to 'A' or 'B' if Alfa Oil consent tier shifts.
// See WORK/briefs/alfa-oil-content-brief.md.
const trustVariant = 'C' as const;
---

<BaseLayout
  title="KKT — AI that ships, not slides."
  description="Senior PMO + AI delivery for mid-sized retailers and fuel networks. Tallinn, EU."
>
  <Hero trustVariant={trustVariant} />

  <section class="section section-industries">
    <div class="container">
      <div class="section-label">Where we work</div>
      <h2 class="h2-section">Two industries. One delivery model.</h2>
      <div class="industry-grid">
        <a href="/industries/retail" class="industry-card">
          <div class="industry-eyebrow">Retail</div>
          <h3 class="industry-title">Mid-sized retailers</h3>
          <p>
            Margin, cash, customer ownership, decision speed. Where AI and PMO
            discipline earn their place against measurable outcomes.
          </p>
          <div class="industry-stat">
            <span class="industry-stat-num">30</span>
            <span class="industry-stat-label">services across 11 retail domains in the open playbook</span>
          </div>
          <span class="industry-arrow">See the playbook →</span>
        </a>

        <a href="/industries/fuel-retail" class="industry-card">
          <div class="industry-eyebrow">Fuel retail</div>
          <h3 class="industry-title">Fuel networks</h3>
          <p>
            Optimus runs price, margin, and operations across stations. Live at
            Alfa Oil — 600+ stations, $500M revenue, in production.
          </p>
          <div class="industry-stat">
            <span class="industry-stat-num">600+</span>
            <span class="industry-stat-label">stations live on Optimus today</span>
          </div>
          <span class="industry-arrow">See Optimus →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="section section-pullquote">
    <div class="container">
      <blockquote class="pullquote">
        <p>
          We are not an AI vendor with a deck. We are a delivery firm
          with deep AI capability.
        </p>
      </blockquote>
    </div>
  </section>

  <section class="section section-featured">
    <div class="container">
      <div class="section-label">Featured case</div>
      <h2 class="h2-section">Alfa Oil — Optimus operating across the network.</h2>
      <div class="featured-grid">
        <div class="featured-card featured-text">
          <p class="featured-body">
            Walk through the engagement: where it started, what shipped,
            what it moved. No vendor-deck claims — just what the system
            does in production today.
          </p>
          <div class="featured-stats">
            <div class="featured-stat">
              <div class="featured-stat-num">600+</div>
              <div class="featured-stat-label">stations</div>
            </div>
            <div class="featured-stat">
              <div class="featured-stat-num">$500M</div>
              <div class="featured-stat-label">revenue</div>
            </div>
            <div class="featured-stat">
              <div class="featured-stat-num">11</div>
              <div class="featured-stat-label">fuel types</div>
            </div>
          </div>
          <a href="/case-studies/alfa-oil" class="btn-ghost featured-cta">Read the case</a>
        </div>
        <div class="featured-card featured-visual">
          <AlfaNetworkMap variant="compact" />
        </div>
      </div>
    </div>
  </section>

  <section class="section section-howweship">
    <div class="container">
      <div class="section-label">How we ship</div>
      <h2 class="h2-section">Delivery, not theatre.</h2>

      <figure class="engagement-arc" aria-label="Engagement arc: Diagnostic over two weeks, then a sequenced engagement, then handover when the system runs without us">
        <svg viewBox="0 0 720 160" xmlns="http://www.w3.org/2000/svg" role="presentation">
          <!-- baseline -->
          <line x1="60" y1="80" x2="660" y2="80" stroke="currentColor" stroke-width="1" stroke-opacity="0.18"/>

          <!-- Phase 1 — Diagnostic -->
          <g>
            <circle cx="120" cy="80" r="16" fill="var(--bg)" stroke="currentColor" stroke-width="1.5"/>
            <text x="120" y="84" font-family="ui-monospace, Menlo, monospace" font-size="11" font-weight="600" fill="currentColor" text-anchor="middle">01</text>
            <text x="120" y="46" font-family="'Playfair Display', serif" font-style="italic" font-size="18" fill="currentColor" text-anchor="middle">Diagnostic</text>
            <text x="120" y="112" font-family="ui-monospace, Menlo, monospace" font-size="10" font-weight="600" fill="#8A5E18" letter-spacing="0.6" text-anchor="middle">2 WEEKS</text>
            <text x="120" y="128" font-family="'DM Sans', sans-serif" font-size="11" fill="currentColor" fill-opacity="0.55" text-anchor="middle">Scope, no commitment</text>
          </g>

          <!-- Arrow 1 → 2 (solid, scoped) -->
          <line x1="138" y1="80" x2="342" y2="80" stroke="currentColor" stroke-opacity="0.35" stroke-width="1.5"/>

          <!-- Phase 2 — Engagement -->
          <g>
            <circle cx="360" cy="80" r="16" fill="var(--bg)" stroke="currentColor" stroke-width="1.5"/>
            <text x="360" y="84" font-family="ui-monospace, Menlo, monospace" font-size="11" font-weight="600" fill="currentColor" text-anchor="middle">02</text>
            <text x="360" y="46" font-family="'Playfair Display', serif" font-style="italic" font-size="18" fill="currentColor" text-anchor="middle">Engagement</text>
            <text x="360" y="112" font-family="ui-monospace, Menlo, monospace" font-size="10" font-weight="600" fill="#8A5E18" letter-spacing="0.6" text-anchor="middle">SHAPED BY WHAT SHIPS</text>
            <text x="360" y="128" font-family="'DM Sans', sans-serif" font-size="11" fill="currentColor" fill-opacity="0.55" text-anchor="middle">PMO + AI delivery, in production</text>
          </g>

          <!-- Arrow 2 → 3 -->
          <line x1="378" y1="80" x2="582" y2="80" stroke="currentColor" stroke-opacity="0.35" stroke-width="1.5"/>

          <!-- Phase 3 — Handover (accent) -->
          <g>
            <circle cx="600" cy="80" r="16" fill="var(--bg)" stroke="#B8832A" stroke-width="2"/>
            <text x="600" y="84" font-family="ui-monospace, Menlo, monospace" font-size="11" font-weight="600" fill="#8A5E18" text-anchor="middle">03</text>
            <text x="600" y="46" font-family="'Playfair Display', serif" font-style="italic" font-size="18" fill="currentColor" text-anchor="middle">Handover</text>
            <text x="600" y="112" font-family="ui-monospace, Menlo, monospace" font-size="10" font-weight="600" fill="#8A5E18" letter-spacing="0.6" text-anchor="middle">EXIT CRITERION</text>
            <text x="600" y="128" font-family="'DM Sans', sans-serif" font-size="11" fill="currentColor" fill-opacity="0.55" text-anchor="middle">System runs without us</text>
          </g>
        </svg>
      </figure>

      <div class="hws-grid">
        <div class="hws-card">
          <div class="hws-eyebrow">01 — Diagnostic</div>
          <h3 class="hws-title">A diagnostic before a programme.</h3>
          <p>
            Two weeks. Scope only. We look before we commit. Output is a
            sharp picture of what to ship, what to leave alone, what proof
            you need before you can decide.
          </p>
        </div>

        <div class="hws-card">
          <div class="hws-eyebrow">02 — Discipline</div>
          <h3 class="hws-title">PMO discipline as load-bearing.</h3>
          <p>
            Scope, sequencing, ownership, shipping under constraint. PMO
            is what separates a slide-led project from one that runs in
            production.
          </p>
        </div>

        <div class="hws-card">
          <div class="hws-eyebrow">03 — Earned place</div>
          <h3 class="hws-title">AI where it earns its place.</h3>
          <p>
            No AI for AI's sake. Margin, cash, availability, customer
            value, productivity — the outcome sets the bar before the tool
            does.
          </p>
        </div>

        <div class="hws-card">
          <div class="hws-eyebrow">04 — Exit</div>
          <h3 class="hws-title">Until the system runs without us.</h3>
          <p>
            Engagements end; the product keeps operating. We design for
            that exit from the first week. Internal counterparts inherit
            the system, not the dependency.
          </p>
        </div>
      </div>

      <p class="hws-tail">
        <a href="/approach" class="hws-link">How an engagement actually runs →</a>
      </p>
    </div>
  </section>

  <CTA />
</BaseLayout>

<style>
  .section-industries {
    padding-top: clamp(48px, 7vh, 80px);
    padding-bottom: clamp(48px, 7vh, 80px);
    border-top: 1px solid var(--border);
  }
  .section-industries .section-label,
  .section-featured .section-label {
    margin-bottom: 12px;
  }
  .section-industries h2 {
    margin-bottom: 36px;
    max-width: 22ch;
  }

  .industry-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }
  @media (min-width: 720px) {
    .industry-grid {
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
  }

  .industry-card {
    display: block;
    padding: 28px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    text-decoration: none;
    transition: border-color .18s ease, transform .18s ease;
    color: inherit;
  }
  .industry-card:hover {
    border-color: var(--border-hover);
    text-decoration: none;
  }
  .industry-eyebrow {
    font-size: 11px;
    color: var(--accent-text);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .industry-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 24px;
    color: var(--text-primary);
    margin-bottom: 10px;
    font-weight: 400;
  }
  .industry-card p {
    font-size: 15px;
    color: var(--text-secondary);
    margin-bottom: 16px;
  }
  .industry-arrow {
    font-size: 13px;
    color: var(--text-primary);
    font-weight: 500;
  }
  .industry-stat {
    margin: 16px 0;
    padding: 12px 0;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: baseline;
    gap: 12px;
  }
  .industry-stat-num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 32px;
    color: var(--accent);
    line-height: 1;
    flex-shrink: 0;
  }
  .industry-stat-label {
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.4;
    max-width: 28ch;
  }

  .section-pullquote {
    padding: clamp(48px, 7vh, 88px) 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--surface-alt);
  }
  .pullquote {
    margin: 0 auto;
    max-width: 760px;
    padding: 0;
  }
  .pullquote p {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(24px, 3.4vw, 38px);
    line-height: 1.25;
    color: var(--text-primary);
    margin: 0;
    max-width: 24ch;
  }

  .section-featured {
    padding-top: clamp(48px, 7vh, 80px);
    padding-bottom: clamp(48px, 7vh, 80px);
  }
  .section-featured h2 {
    margin-bottom: 28px;
    max-width: 22ch;
  }
  .featured-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    align-items: stretch;
  }
  @media (min-width: 880px) {
    .featured-grid {
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
  }
  .featured-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 28px;
    display: flex;
    flex-direction: column;
  }
  .featured-text {
    justify-content: space-between;
  }
  .featured-body {
    margin-bottom: 24px;
  }
  .featured-stats {
    display: flex;
    gap: 28px;
    margin-bottom: 28px;
    flex-wrap: wrap;
  }
  .featured-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .featured-stat-num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 36px;
    color: var(--accent);
    line-height: 1;
  }
  .featured-stat-label {
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 600;
  }
  .featured-cta {
    align-self: flex-start;
  }
  .featured-visual {
    justify-content: center;
    align-items: stretch;
  }

  .section-howweship {
    padding-top: clamp(48px, 7vh, 80px);
    padding-bottom: clamp(48px, 7vh, 80px);
    border-top: 1px solid var(--border);
    background: var(--surface-alt);
  }
  .section-howweship .section-label { margin-bottom: 12px; }
  .section-howweship h2 { margin-bottom: 28px; max-width: 22ch; }

  .engagement-arc {
    margin: 0 0 36px;
    padding: 28px 32px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text-primary);
  }
  .engagement-arc svg { width: 100%; height: auto; display: block; }

  .hws-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
    margin-bottom: 28px;
  }
  @media (min-width: 720px) {
    .hws-grid { grid-template-columns: 1fr 1fr; }
  }
  .hws-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 24px 26px;
  }
  .hws-eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent-text);
    font-weight: 600;
    letter-spacing: 0.06em;
    margin-bottom: 12px;
  }
  .hws-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 22px;
    color: var(--text-primary);
    margin-bottom: 10px;
    line-height: 1.2;
  }
  .hws-card p { font-size: 15px; max-width: 50ch; }
  .hws-tail { margin-top: 8px; }
  .hws-link {
    font-size: 14px;
    color: var(--text-primary);
    font-weight: 500;
    text-decoration: none;
  }
  .hws-link:hover { text-decoration: underline; text-underline-offset: 3px; text-decoration-color: var(--accent); }
</style>
