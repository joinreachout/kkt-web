---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTA from '~/components/CTA.astro';

const clusters = [
  {
    name: 'What you see on day one',
    eyebrow: 'Visibility',
    items: [
      { name: 'AI Briefing', body: 'Plain-language daily summary — Action Required, Good News, Savings Tip. Free-form chat answers questions from live data.' },
      { name: 'Stockout Forecast', body: 'Days remaining until critical level per station × fuel. Includes in-transit and split-wagon transfers.' },
      { name: 'Fuel Level Forecast', body: 'Per-station stock projection charts with region and fuel filters.' },
      { name: 'Station Fill Levels', body: 'Per-station, per-fuel % capacity and tonnage, sorted by urgency.' },
    ],
  },
  {
    name: 'What you act on',
    eyebrow: 'Decision surface',
    items: [
      { name: 'Procurement Advisor', body: 'Concrete order recommendations with supplier, tonnage, deadline, price. Statuses CRITICAL / ORDER / OK. One-click PO creation.' },
      { name: 'Reserves Panel', body: 'Fuel held at supplier without destination. Release reserve assigns to a specific station with capacity check.' },
      { name: 'Delivery conflict resolver', body: 'Auto-Distribute reroutes overflow wagons to nearest stations with free capacity. Audit trail.' },
      { name: 'Forced Order flow', body: 'Senior management override path with audit trail and ship-history fallback.' },
    ],
  },
  {
    name: 'What you track over time',
    eyebrow: 'History & money',
    items: [
      { name: 'Working Capital', body: '$ frozen in inventory and where to release.' },
      { name: 'Inventory Turnover', body: 'Per-fuel turnover rate, days on hand, value at stake.' },
      { name: 'Recommendation History', body: 'Daily snapshots — rewind to any past day to see what was advised and what happened.' },
      { name: 'Shipments Timeline', body: '14 / 30 / 60-day forward view per station. Color-coded OK / Tight / Conflict.' },
    ],
  },
  {
    name: 'What runs without you',
    eyebrow: 'Autonomous',
    items: [
      { name: 'Auto-import (cron, ~03:30 local)', body: 'Pulls fresh stocks and orders from ERP. No manual upload.' },
      { name: 'Telegram alert mirror', body: 'Critical events pushed to operator group regardless of web availability.' },
    ],
  },
];
---

<BaseLayout
  title="Optimus — KKT"
  description="Daily operating intelligence for fuel networks. Stockouts, replenishment, working capital — in 10 minutes a morning."
>
  <article class="prose-page">
    <div class="container">
      <div class="section-label">Solutions — Optimus</div>
      <h1 class="h1-page">Optimus.</h1>
      <p class="hero-sub">Daily operating intelligence for fuel networks.</p>
      <p class="lede">
        Optimus is an operating-intelligence system for fuel-distribution
        networks. Each morning it pulls live data from ERP — current stocks,
        in-transit orders, station-level sales, supplier offers — forecasts
        when each station × fuel-type position will hit critical level,
        detects inbound delivery conflicts where arriving volume exceeds
        tank capacity, and produces concrete procurement recommendations:
        which supplier, how many tons, by what date, at what price.
      </p>

      <div class="cta-row">
        <a href="/contact?subject=Optimus%20demo" class="btn-primary">Book a demo</a>
        <a href="/case-studies/alfa-oil" class="btn-ghost">Read the Alfa Oil case</a>
      </div>

      <figure class="optimus-flow" aria-label="Optimus daily pulse: ERP cron import at 03:30, forecast engine, recommendations, operator at 08:00, Telegram mirror">
        <svg viewBox="0 0 760 220" xmlns="http://www.w3.org/2000/svg" role="presentation">
          <defs>
            <marker id="arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto">
              <path d="M0,0 L10,5 L0,10 Z" fill="currentColor" fill-opacity="0.45"/>
            </marker>
          </defs>

          <!-- Time pin: 03:30 -->
          <text x="60" y="32" font-family="ui-monospace, Menlo, monospace" font-size="11" font-weight="600" fill="#8A5E18" letter-spacing="0.5" text-anchor="middle">03:30</text>
          <line x1="60" y1="42" x2="60" y2="62" stroke="#B8832A" stroke-width="1.5"/>

          <!-- Box 1: ERP cron import -->
          <g>
            <rect x="14" y="64" width="92" height="56" rx="4" fill="#FFFFFF" stroke="currentColor" stroke-opacity="0.15"/>
            <text x="60" y="86" font-family="'DM Sans', sans-serif" font-size="13" font-weight="600" fill="currentColor" text-anchor="middle">ERP</text>
            <text x="60" y="103" font-family="'DM Sans', sans-serif" font-size="11" fill="currentColor" fill-opacity="0.6" text-anchor="middle">cron import</text>
          </g>
          <text x="60" y="142" font-family="'DM Sans', sans-serif" font-size="11" fill="currentColor" fill-opacity="0.55" text-anchor="middle">Stocks · in-transit · sales</text>

          <!-- Arrow 1 -->
          <line x1="110" y1="92" x2="158" y2="92" stroke="currentColor" stroke-opacity="0.45" stroke-width="1.5" marker-end="url(#arrow)"/>

          <!-- Box 2: Forecast engine -->
          <g>
            <rect x="162" y="64" width="118" height="56" rx="4" fill="#FFFFFF" stroke="currentColor" stroke-opacity="0.15"/>
            <text x="221" y="86" font-family="'DM Sans', sans-serif" font-size="13" font-weight="600" fill="currentColor" text-anchor="middle">Forecast engine</text>
            <text x="221" y="103" font-family="'DM Sans', sans-serif" font-size="11" fill="currentColor" fill-opacity="0.6" text-anchor="middle">stockout × delivery</text>
          </g>

          <!-- Arrow 2 -->
          <line x1="284" y1="92" x2="332" y2="92" stroke="currentColor" stroke-opacity="0.45" stroke-width="1.5" marker-end="url(#arrow)"/>

          <!-- Box 3: Procurement Advisor -->
          <g>
            <rect x="336" y="64" width="138" height="56" rx="4" fill="#FFFFFF" stroke="currentColor" stroke-opacity="0.15"/>
            <text x="405" y="86" font-family="'DM Sans', sans-serif" font-size="13" font-weight="600" fill="currentColor" text-anchor="middle">Procurement Advisor</text>
            <text x="405" y="103" font-family="'DM Sans', sans-serif" font-size="11" fill="currentColor" fill-opacity="0.6" text-anchor="middle">supplier · tonnage · price</text>
          </g>

          <!-- Arrow 3 -->
          <line x1="478" y1="92" x2="526" y2="92" stroke="currentColor" stroke-opacity="0.45" stroke-width="1.5" marker-end="url(#arrow)"/>

          <!-- Time pin: 08:00 -->
          <text x="588" y="32" font-family="ui-monospace, Menlo, monospace" font-size="11" font-weight="600" fill="#8A5E18" letter-spacing="0.5" text-anchor="middle">08:00</text>
          <line x1="588" y1="42" x2="588" y2="62" stroke="#B8832A" stroke-width="1.5"/>

          <!-- Box 4: Operator -->
          <g>
            <rect x="530" y="64" width="116" height="56" rx="4" fill="#1A1410" stroke="#1A1410"/>
            <text x="588" y="86" font-family="'DM Sans', sans-serif" font-size="13" font-weight="600" fill="#F5F3EF" text-anchor="middle">Operator</text>
            <text x="588" y="103" font-family="'DM Sans', sans-serif" font-size="11" fill="#F5F3EF" fill-opacity="0.7" text-anchor="middle">10–15 min morning</text>
          </g>

          <!-- Branch arrow down to Telegram -->
          <line x1="588" y1="124" x2="588" y2="156" stroke="currentColor" stroke-opacity="0.45" stroke-width="1.5" marker-end="url(#arrow)"/>

          <!-- Box 5: Telegram alerts -->
          <g>
            <rect x="514" y="160" width="148" height="42" rx="4" fill="#FFFFFF" stroke="currentColor" stroke-opacity="0.15"/>
            <text x="588" y="178" font-family="'DM Sans', sans-serif" font-size="12" font-weight="600" fill="currentColor" text-anchor="middle">Telegram mirror</text>
            <text x="588" y="193" font-family="'DM Sans', sans-serif" font-size="10" fill="currentColor" fill-opacity="0.6" text-anchor="middle">critical alerts only</text>
          </g>

          <!-- Confirmation feedback arrow (Operator → Procurement Advisor) -->
          <path d="M 530 110 Q 470 145, 420 124" fill="none" stroke="currentColor" stroke-opacity="0.25" stroke-width="1" stroke-dasharray="3 3" marker-end="url(#arrow)"/>
          <text x="475" y="155" font-family="'DM Sans', sans-serif" font-size="10" fill="currentColor" fill-opacity="0.45" text-anchor="middle" font-style="italic">confirm / override</text>
        </svg>
        <figcaption class="optimus-flow-caption">
          Daily pulse: data lands at 03:30, the head of supply opens
          Optimus at 08:00, ten to fifteen minutes later the day&rsquo;s
          procurement decisions are issued. Critical events mirror to
          Telegram independently of the web interface.
        </figcaption>
      </figure>
    </div>

    <section class="section section-morning">
      <div class="container">
        <div class="section-label">A morning at the operator's desk</div>
        <h2 class="h2-section">Ten to fifteen minutes, then the day starts.</h2>

        <ol class="morning-steps">
          <li>
            <div class="step-num">1</div>
            <div>
              <div class="step-name">8:00 AM — Open the briefing.</div>
              <p>
                The head of supply opens Optimus and sees yesterday's
                pipeline freshness in one glance, not 40 minutes of
                reconciliation. Action Required. Good News. Savings Tip.
                What changed since yesterday.
              </p>
            </div>
          </li>
          <li>
            <div class="step-num">2</div>
            <div>
              <div class="step-name">Close critical positions.</div>
              <p>
                Procurement Advisor surfaces every station × fuel that
                will hit critical level inside the planning window. Each
                row already has a recommended supplier, tonnage, and
                deadline. Confirm or override.
              </p>
            </div>
          </li>
          <li>
            <div class="step-num">3</div>
            <div>
              <div class="step-name">Resolve delivery conflicts.</div>
              <p>
                When inbound volume exceeds available tank capacity,
                Auto-Distribute reroutes overflow to the nearest stations
                with free capacity. The operator sees the proposed routing,
                not just an alert.
              </p>
            </div>
          </li>
          <li>
            <div class="step-num">4</div>
            <div>
              <div class="step-name">Issue the POs.</div>
              <p>
                One-click PO creation on confirmed recommendations. The
                Reserves Panel covers any fuel already held at supplier
                without destination — assign it to a station with capacity
                check.
              </p>
            </div>
          </li>
          <li>
            <div class="step-num">5</div>
            <div>
              <div class="step-name">Walk away.</div>
              <p>
                Critical alerts mirror to a Telegram group. The operator
                does not depend on the web interface for the rest of the
                day.
              </p>
            </div>
          </li>
        </ol>
      </div>
    </section>

    <section class="section section-changes">
      <div class="container">
        <div class="section-label">What it actually changes</div>
        <h2 class="h2-section">Outcomes, not features.</h2>
        <div class="outcomes-grid">
          <div class="outcome">
            <div class="outcome-title">Stockouts</div>
            <p>
              Fewer surprise critical positions. The forecast surfaces them
              days before they happen, when there is still time to act.
            </p>
          </div>
          <div class="outcome">
            <div class="outcome-title">Working capital</div>
            <p>
              $ frozen in inventory becomes visible per fuel and per region
              — and so does where to release it. Inventory turnover stops
              being a quarterly review and becomes a daily decision.
            </p>
          </div>
          <div class="outcome">
            <div class="outcome-title">Procurement speed</div>
            <p>
              Decisions that took half a day of reconciliation move to
              minutes. The operator sees the recommendation and the data
              behind it on the same screen.
            </p>
          </div>
          <div class="outcome">
            <div class="outcome-title">Supplier consolidation</div>
            <p>
              Recommendation history makes supplier-by-supplier savings
              visible over time. The Procurement Advisor's defaults shift
              with what the data shows.
            </p>
          </div>
        </div>
        <p class="outcomes-note">
          Numbers per deployment vary by network size, fuel mix, and
          baseline. We publish ranges from real production environments,
          not vendor-deck promises. See the Alfa Oil case for one
          deployment's actual movement.
        </p>
      </div>
    </section>

    <section class="section section-how">
      <div class="container">
        <div class="section-label">How it works</div>
        <h2 class="h2-section">The full functional surface, in four clusters.</h2>
        <p class="how-lede">
          Fourteen capabilities, organised by how the operator
          actually meets them — what you see, what you act on, what
          you track over time, and what runs without you.
        </p>

        <div class="clusters">
          {clusters.map((cluster) => (
            <div class="cluster">
              <div class="cluster-eyebrow">{cluster.eyebrow}</div>
              <h3 class="cluster-name">{cluster.name}.</h3>
              <ul class="cluster-items">
                {cluster.items.map((item) => (
                  <li>
                    <div class="item-name">{item.name}</div>
                    <p>{item.body}</p>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-deployments">
      <div class="container">
        <div class="section-label">Two live deployments</div>
        <h2 class="h2-section">Same product. Same engine. Different scale.</h2>
        <div class="deployments">
          <div class="deployment">
            <div class="deployment-name">Alfa Oil</div>
            <div class="deployment-meta">Kyrgyzstan · 600+ stations · $500M revenue</div>
            <p>
              Optimus operating across the full network. Pricing posture,
              station-level operations, supplier relationships — under one
              roof.
            </p>
            <a href="/case-studies/alfa-oil" class="deployment-link">Read the case →</a>
          </div>
          <div class="deployment">
            <div class="deployment-name">Central Asian fuel network</div>
            <div class="deployment-meta">10 stations · 11 fuel types · 3 regions</div>
            <p>
              The smaller end of the range. Same Optimus engine, configured
              for a tight network with multiple fuel types and regional
              supply variability.
            </p>
            <span class="deployment-link muted">Case study in editorial</span>
          </div>
        </div>
      </div>
    </section>

    <CTA
      heading="See if Optimus fits your network."
      body="A two-week diagnostic looks at your pricing posture, margin posture, and station-level operations — and tells you what shipping Optimus into your network would actually look like."
      primaryLabel="Book a diagnostic"
      primaryHref="/contact?subject=Optimus%20diagnostic"
      secondaryLabel="Read the Alfa Oil case"
      secondaryHref="/case-studies/alfa-oil"
    />
  </article>
</BaseLayout>

<style>
  .prose-page { padding-top: clamp(40px, 6vh, 72px); }
  .section-label { margin-bottom: 18px; }
  .h1-page {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.14;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }
  .hero-sub {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(20px, 2.6vw, 28px);
    color: var(--text-secondary);
    margin-bottom: 24px;
    max-width: 36ch;
  }
  .lede {
    font-size: clamp(16px, 1.7vw, 18px);
    color: var(--text-secondary);
    line-height: 1.65;
    max-width: 68ch;
    margin-bottom: 32px;
  }
  .cta-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }

  .optimus-flow {
    margin: 36px 0 0;
    padding: 24px 28px 22px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text-primary);
    max-width: 820px;
  }
  .optimus-flow svg {
    width: 100%;
    height: auto;
    display: block;
  }
  .optimus-flow-caption {
    margin-top: 16px;
    font-size: 13px;
    color: var(--text-muted);
    max-width: 60ch;
  }

  .section {
    border-top: 1px solid var(--border);
    margin-top: 48px;
  }
  .section .section-label { margin-bottom: 12px; }
  .section h2 { margin-bottom: 36px; max-width: 24ch; }

  .section-morning {
    background: var(--surface-alt);
    margin-left: -100vw;
    margin-right: -100vw;
    padding-left: 100vw;
    padding-right: 100vw;
  }
  .morning-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 18px;
    max-width: 760px;
  }
  .morning-steps li {
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: 16px;
    padding: 22px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
  }
  .step-num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 24px;
    color: var(--accent-text);
    line-height: 1;
  }
  .step-name {
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 6px;
    font-size: 16px;
  }
  .morning-steps p { font-size: 15px; max-width: 60ch; }

  .outcomes-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
    margin-bottom: 24px;
  }
  @media (min-width: 720px) {
    .outcomes-grid { grid-template-columns: 1fr 1fr; }
  }
  .outcome {
    padding: 22px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
  }
  .outcome-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 22px;
    color: var(--text-primary);
    margin-bottom: 10px;
    font-weight: 400;
  }
  .outcome p { font-size: 15px; }
  .outcomes-note {
    font-size: 13px;
    color: var(--text-muted);
    max-width: 60ch;
    margin-top: 18px;
  }

  .how-lede {
    max-width: 60ch;
    margin-bottom: 32px;
  }
  .clusters {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }
  @media (min-width: 880px) {
    .clusters { grid-template-columns: 1fr 1fr; gap: 22px; }
  }
  .cluster {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 24px 26px;
    display: flex;
    flex-direction: column;
  }
  .cluster-eyebrow {
    font-size: 11px;
    color: var(--accent-text);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .cluster-name {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(20px, 2.4vw, 26px);
    color: var(--text-primary);
    margin-bottom: 18px;
    line-height: 1.2;
  }
  .cluster-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .cluster-items li {
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border);
  }
  .cluster-items li:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }
  .item-name {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 14px;
    margin-bottom: 4px;
  }
  .cluster-items p {
    font-size: 14px;
    line-height: 1.55;
    margin: 0;
  }

  .deployments {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }
  @media (min-width: 720px) {
    .deployments { grid-template-columns: 1fr 1fr; }
  }
  .deployment {
    padding: 24px 26px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
  }
  .deployment-name {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 26px;
    color: var(--text-primary);
    margin-bottom: 6px;
  }
  .deployment-meta {
    font-size: 12px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    margin-bottom: 14px;
  }
  .deployment p { font-size: 15px; margin-bottom: 16px; max-width: 56ch; }
  .deployment-link {
    font-size: 13px;
    color: var(--text-primary);
    font-weight: 500;
  }
  .deployment-link.muted {
    color: var(--text-muted);
    font-style: italic;
  }
</style>
