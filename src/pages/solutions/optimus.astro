---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTA from '~/components/CTA.astro';

const capabilities = [
  { name: 'Auto-import (cron, ~03:30 local)', body: 'Pulls fresh stocks and orders from ERP. No manual upload.' },
  { name: 'AI Briefing', body: 'Plain-language daily situation summary: Action Required, Good News, Savings Tip. Free-form chat answers questions from live data.' },
  { name: 'Procurement Advisor', body: 'Concrete order recommendations with supplier, tonnage, deadline, price. Statuses CRITICAL / ORDER / OK. One-click PO creation.' },
  { name: 'Shipments Timeline', body: '14 / 30 / 60-day forward view per station. Color-coded OK / Tight / Conflict.' },
  { name: 'Delivery conflict resolver', body: 'Auto-Distribute reroutes overflow wagons to nearest stations with free capacity. Audit trail.' },
  { name: 'Stockout Forecast', body: 'Days remaining until critical level per station × fuel position. Includes in-transit and split-wagon transfers.' },
  { name: 'Fuel Level Forecast', body: 'Per-station stock projection charts with region and fuel filters.' },
  { name: 'Reserves Panel', body: 'Fuel held at supplier without destination. Release reserve assigns to a specific station with capacity check.' },
  { name: 'Station Fill Levels', body: 'Per-station, per-fuel % capacity and tonnage, sorted by urgency.' },
  { name: 'Working Capital', body: '$ frozen in inventory and where to release.' },
  { name: 'Inventory Turnover', body: 'Per-fuel turnover rate, days on hand, value at stake.' },
  { name: 'Recommendation History', body: 'Daily snapshots — rewind to any past day to see what was advised and what happened.' },
  { name: 'Telegram alert mirror', body: 'Critical events pushed to operator group regardless of web availability.' },
  { name: 'Forced Order flow', body: 'Senior management override path with audit trail and ship-history fallback.' },
];
---

<BaseLayout
  title="Optimus — KKT"
  description="Daily operating intelligence for fuel networks. Stockouts, replenishment, working capital — in 10 minutes a morning."
>
  <article class="prose-page">
    <div class="container">
      <div class="section-label">Solutions — Optimus</div>
      <h1 class="h1-page">Optimus.</h1>
      <p class="hero-sub">Daily operating intelligence for fuel networks.</p>
      <p class="lede">
        Optimus is an operating-intelligence system for fuel-distribution
        networks. Each morning it pulls live data from ERP — current stocks,
        in-transit orders, station-level sales, supplier offers — forecasts
        when each station × fuel-type position will hit critical level,
        detects inbound delivery conflicts where arriving volume exceeds
        tank capacity, and produces concrete procurement recommendations:
        which supplier, how many tons, by what date, at what price.
      </p>

      <div class="cta-row">
        <a href="/contact?subject=Optimus%20demo" class="btn-primary">Book a demo</a>
        <a href="/case-studies/alfa-oil" class="btn-ghost">Read the Alfa Oil case</a>
      </div>
    </div>

    <section class="section section-morning">
      <div class="container">
        <div class="section-label">A morning at the operator's desk</div>
        <h2 class="h2-section">Ten to fifteen minutes, then the day starts.</h2>

        <ol class="morning-steps">
          <li>
            <div class="step-num">1</div>
            <div>
              <div class="step-name">8:00 AM — Open the briefing.</div>
              <p>
                The head of supply opens Optimus and sees yesterday's
                pipeline freshness in one glance, not 40 minutes of
                reconciliation. Action Required. Good News. Savings Tip.
                What changed since yesterday.
              </p>
            </div>
          </li>
          <li>
            <div class="step-num">2</div>
            <div>
              <div class="step-name">Close critical positions.</div>
              <p>
                Procurement Advisor surfaces every station × fuel that
                will hit critical level inside the planning window. Each
                row already has a recommended supplier, tonnage, and
                deadline. Confirm or override.
              </p>
            </div>
          </li>
          <li>
            <div class="step-num">3</div>
            <div>
              <div class="step-name">Resolve delivery conflicts.</div>
              <p>
                When inbound volume exceeds available tank capacity,
                Auto-Distribute reroutes overflow to the nearest stations
                with free capacity. The operator sees the proposed routing,
                not just an alert.
              </p>
            </div>
          </li>
          <li>
            <div class="step-num">4</div>
            <div>
              <div class="step-name">Issue the POs.</div>
              <p>
                One-click PO creation on confirmed recommendations. The
                Reserves Panel covers any fuel already held at supplier
                without destination — assign it to a station with capacity
                check.
              </p>
            </div>
          </li>
          <li>
            <div class="step-num">5</div>
            <div>
              <div class="step-name">Walk away.</div>
              <p>
                Critical alerts mirror to a Telegram group. The operator
                does not depend on the web interface for the rest of the
                day.
              </p>
            </div>
          </li>
        </ol>
      </div>
    </section>

    <section class="section section-changes">
      <div class="container">
        <div class="section-label">What it actually changes</div>
        <h2 class="h2-section">Outcomes, not features.</h2>
        <div class="outcomes-grid">
          <div class="outcome">
            <div class="outcome-title">Stockouts</div>
            <p>
              Fewer surprise critical positions. The forecast surfaces them
              days before they happen, when there is still time to act.
            </p>
          </div>
          <div class="outcome">
            <div class="outcome-title">Working capital</div>
            <p>
              $ frozen in inventory becomes visible per fuel and per region
              — and so does where to release it. Inventory turnover stops
              being a quarterly review and becomes a daily decision.
            </p>
          </div>
          <div class="outcome">
            <div class="outcome-title">Procurement speed</div>
            <p>
              Decisions that took half a day of reconciliation move to
              minutes. The operator sees the recommendation and the data
              behind it on the same screen.
            </p>
          </div>
          <div class="outcome">
            <div class="outcome-title">Supplier consolidation</div>
            <p>
              Recommendation history makes supplier-by-supplier savings
              visible over time. The Procurement Advisor's defaults shift
              with what the data shows.
            </p>
          </div>
        </div>
        <p class="outcomes-note">
          Numbers per deployment vary by network size, fuel mix, and
          baseline. We publish ranges from real production environments,
          not vendor-deck promises. See the Alfa Oil case for one
          deployment's actual movement.
        </p>
      </div>
    </section>

    <section class="section section-how">
      <div class="container">
        <div class="section-label">How it works</div>
        <h2 class="h2-section">The full functional surface.</h2>
        <ul class="capabilities">
          {capabilities.map((c) => (
            <li>
              <div class="capability-name">{c.name}</div>
              <p>{c.body}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="section section-deployments">
      <div class="container">
        <div class="section-label">Two live deployments</div>
        <h2 class="h2-section">Same product. Same engine. Different scale.</h2>
        <div class="deployments">
          <div class="deployment">
            <div class="deployment-name">Alfa Oil</div>
            <div class="deployment-meta">Kyrgyzstan · 600+ stations · $500M revenue</div>
            <p>
              Optimus operating across the full network. Pricing posture,
              station-level operations, supplier relationships — under one
              roof.
            </p>
            <a href="/case-studies/alfa-oil" class="deployment-link">Read the case →</a>
          </div>
          <div class="deployment">
            <div class="deployment-name">Central Asian fuel network</div>
            <div class="deployment-meta">10 stations · 11 fuel types · 3 regions</div>
            <p>
              The smaller end of the range. Same Optimus engine, configured
              for a tight network with multiple fuel types and regional
              supply variability.
            </p>
            <span class="deployment-link muted">Case study in editorial</span>
          </div>
        </div>
      </div>
    </section>

    <CTA
      heading="See if Optimus fits your network."
      body="A two-week diagnostic looks at your pricing posture, margin posture, and station-level operations — and tells you what shipping Optimus into your network would actually look like."
      primaryLabel="Book a diagnostic"
      primaryHref="/contact?subject=Optimus%20diagnostic"
      secondaryLabel="Read the Alfa Oil case"
      secondaryHref="/case-studies/alfa-oil"
    />
  </article>
</BaseLayout>

<style>
  .prose-page { padding-top: clamp(40px, 6vh, 72px); }
  .section-label { margin-bottom: 18px; }
  .h1-page {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.14;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }
  .hero-sub {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(20px, 2.6vw, 28px);
    color: var(--text-secondary);
    margin-bottom: 24px;
    max-width: 36ch;
  }
  .lede {
    font-size: clamp(16px, 1.7vw, 18px);
    color: var(--text-secondary);
    line-height: 1.65;
    max-width: 68ch;
    margin-bottom: 32px;
  }
  .cta-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }

  .section {
    border-top: 1px solid var(--border);
    margin-top: 48px;
  }
  .section .section-label { margin-bottom: 12px; }
  .section h2 { margin-bottom: 36px; max-width: 24ch; }

  .section-morning {
    background: var(--surface-alt);
    margin-left: -100vw;
    margin-right: -100vw;
    padding-left: 100vw;
    padding-right: 100vw;
  }
  .morning-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 18px;
    max-width: 760px;
  }
  .morning-steps li {
    display: grid;
    grid-template-columns: 36px 1fr;
    gap: 16px;
    padding: 22px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
  }
  .step-num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 24px;
    color: var(--accent-text);
    line-height: 1;
  }
  .step-name {
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 6px;
    font-size: 16px;
  }
  .morning-steps p { font-size: 15px; max-width: 60ch; }

  .outcomes-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
    margin-bottom: 24px;
  }
  @media (min-width: 720px) {
    .outcomes-grid { grid-template-columns: 1fr 1fr; }
  }
  .outcome {
    padding: 22px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
  }
  .outcome-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 22px;
    color: var(--text-primary);
    margin-bottom: 10px;
    font-weight: 400;
  }
  .outcome p { font-size: 15px; }
  .outcomes-note {
    font-size: 13px;
    color: var(--text-muted);
    max-width: 60ch;
    margin-top: 18px;
  }

  .capabilities {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
  }
  @media (min-width: 720px) {
    .capabilities { grid-template-columns: 1fr 1fr; }
  }
  .capabilities li {
    background: var(--surface);
    padding: 18px 22px;
  }
  .capability-name {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 14px;
    margin-bottom: 6px;
  }
  .capabilities p { font-size: 14px; line-height: 1.55; }

  .deployments {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }
  @media (min-width: 720px) {
    .deployments { grid-template-columns: 1fr 1fr; }
  }
  .deployment {
    padding: 24px 26px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
  }
  .deployment-name {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 26px;
    color: var(--text-primary);
    margin-bottom: 6px;
  }
  .deployment-meta {
    font-size: 12px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    margin-bottom: 14px;
  }
  .deployment p { font-size: 15px; margin-bottom: 16px; max-width: 56ch; }
  .deployment-link {
    font-size: 13px;
    color: var(--text-primary);
    font-weight: 500;
  }
  .deployment-link.muted {
    color: var(--text-muted);
    font-style: italic;
  }
</style>
