---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTA from '~/components/CTA.astro';

const stages = [
  {
    n: '01',
    name: 'Strengthen the core',
    body: 'Data, governance, decision-grade visibility. The unsexy work that makes everything after it possible.',
  },
  {
    n: '02',
    name: 'Optimize and grow',
    body: 'AI and PMO discipline applied where they earn their place — margin, cash, availability, customer value, productivity.',
  },
  {
    n: '03',
    name: 'Expand and monetize',
    body: 'New revenue, supplier monetization, customer ownership, strategic expansion. The stage where the system runs without us.',
  },
];
---

<BaseLayout
  title="Approach — KKT"
  description="Senior PMO + AI delivery. A staged model from strengthening the core to expanding and monetizing."
>
  <article class="prose-page">
    <div class="container">
      <div class="section-label">Approach</div>
      <h1 class="h1-page">A delivery model, not a deck.</h1>
      <p class="lede">
        We work in three stages. Most clients enter at stage one or two —
        they think they need stage three. The diagnostic tells us which
        one is real.
      </p>

      <figure class="stages-diagram" aria-label="Three-stage progression: Strengthen the core, Optimize and grow, Expand and monetize">
        <svg viewBox="0 0 720 96" xmlns="http://www.w3.org/2000/svg" role="presentation">
          <!-- baseline -->
          <line x1="60" y1="48" x2="660" y2="48" stroke="currentColor" stroke-width="1" stroke-opacity="0.18"/>

          <!-- Stage 1 -->
          <g>
            <circle cx="100" cy="48" r="14" fill="var(--bg)" stroke="currentColor" stroke-width="1.5"/>
            <text x="100" y="52" font-family="ui-monospace, Menlo, monospace" font-size="11" font-weight="600" fill="currentColor" text-anchor="middle">01</text>
            <text x="100" y="22" font-family="'Playfair Display', serif" font-style="italic" font-size="14" fill="currentColor" text-anchor="middle">Strengthen</text>
            <text x="100" y="82" font-family="'DM Sans', sans-serif" font-size="11" fill="currentColor" fill-opacity="0.55" text-anchor="middle">Foundation</text>
          </g>

          <!-- Arrow 1 → 2 -->
          <line x1="116" y1="48" x2="344" y2="48" stroke="currentColor" stroke-opacity="0.35" stroke-width="1.5"/>

          <!-- Stage 2 -->
          <g>
            <circle cx="360" cy="48" r="14" fill="var(--bg)" stroke="currentColor" stroke-width="1.5"/>
            <text x="360" y="52" font-family="ui-monospace, Menlo, monospace" font-size="11" font-weight="600" fill="currentColor" text-anchor="middle">02</text>
            <text x="360" y="22" font-family="'Playfair Display', serif" font-style="italic" font-size="14" fill="currentColor" text-anchor="middle">Optimize</text>
            <text x="360" y="82" font-family="'DM Sans', sans-serif" font-size="11" fill="currentColor" fill-opacity="0.55" text-anchor="middle">Decisions</text>
          </g>

          <!-- Arrow 2 → 3 -->
          <line x1="376" y1="48" x2="604" y2="48" stroke="currentColor" stroke-opacity="0.35" stroke-width="1.5" stroke-dasharray="4 4"/>

          <!-- Stage 3 (dashed because optional / maturity-dependent) -->
          <g>
            <circle cx="620" cy="48" r="14" fill="var(--bg)" stroke="#B8832A" stroke-width="1.5"/>
            <text x="620" y="52" font-family="ui-monospace, Menlo, monospace" font-size="11" font-weight="600" fill="#8A5E18" text-anchor="middle">03</text>
            <text x="620" y="22" font-family="'Playfair Display', serif" font-style="italic" font-size="14" fill="currentColor" text-anchor="middle">Expand</text>
            <text x="620" y="82" font-family="'DM Sans', sans-serif" font-size="11" fill="#8A5E18" fill-opacity="0.85" text-anchor="middle">Optional</text>
          </g>
        </svg>
        <figcaption class="stages-caption">
          Most clients enter at stage 1 or 2. Stage 3 is dashed because
          it&rsquo;s optional and maturity-dependent — never the first
          recommendation.
        </figcaption>
      </figure>

      <section class="stages">
        {stages.map((s) => (
          <div class="stage">
            <div class="stage-num">{s.n}</div>
            <h2 class="stage-name">{s.name}</h2>
            <p>{s.body}</p>
          </div>
        ))}
      </section>

      <section class="pmo-note">
        <h2 class="h2-section">PMO is the rigor.</h2>
        <p>
          We are not an AI vendor. We are a delivery firm with deep AI
          capability. PMO discipline — scope, sequencing, ownership,
          shipping under constraint — is what separates a slide-led
          project from one that runs in production.
        </p>
      </section>
    </div>

    <section class="approach-pullquote">
      <div class="container">
        <blockquote>
          <p>
            If the case for an engagement is not there, we say so at
            the readout. Honest answers beat a sold project.
          </p>
        </blockquote>
      </div>
    </section>

    <div class="container">
      <section class="diag">
        <div class="section-label">Inside a diagnostic</div>
        <div class="diag-head">
          <div class="diag-head-text">
            <h2 class="h2-section">Two weeks. One sharp picture.</h2>
            <p class="diag-lede">
              Every engagement we accept starts with a diagnostic. Two
              weeks, fixed-shape, focused on a single output: a sharp
              picture of what to ship, what to leave alone, and what
              proof you need before committing to the next stage.
            </p>
          </div>
          <div class="diag-head-stat">
            <div class="diag-stat-num">14</div>
            <div class="diag-stat-label">days, fixed shape</div>
          </div>
        </div>

        <figure class="diag-timeline" aria-label="14-day diagnostic timeline showing four phases: Kick-off, Investigation, Synthesis, Readout">
          <svg viewBox="0 0 720 110" xmlns="http://www.w3.org/2000/svg" role="presentation">
            <!-- baseline -->
            <line x1="20" y1="68" x2="700" y2="68" stroke="currentColor" stroke-width="1" stroke-opacity="0.18"/>

            <!-- phase 1: Kick-off, days 1-3, occupies ~21% -->
            <g>
              <line x1="20" y1="62" x2="20" y2="74" stroke="currentColor" stroke-width="1.5"/>
              <line x1="167" y1="62" x2="167" y2="74" stroke="currentColor" stroke-width="1"/>
              <text x="20" y="56" font-family="ui-monospace, Menlo, monospace" font-size="10" font-weight="600" fill="#8A5E18" letter-spacing="0.6">DAYS 1–3</text>
              <text x="20" y="92" font-family="'Playfair Display', serif" font-style="italic" font-size="16" fill="currentColor">Kick-off &amp; access</text>
            </g>

            <!-- phase 2: Investigation, days 4-9 -->
            <g>
              <line x1="167" y1="62" x2="167" y2="74" stroke="currentColor" stroke-width="1.5"/>
              <line x1="461" y1="62" x2="461" y2="74" stroke="currentColor" stroke-width="1"/>
              <text x="167" y="56" font-family="ui-monospace, Menlo, monospace" font-size="10" font-weight="600" fill="#8A5E18" letter-spacing="0.6">DAYS 4–9</text>
              <text x="167" y="92" font-family="'Playfair Display', serif" font-style="italic" font-size="16" fill="currentColor">Investigation</text>
            </g>

            <!-- phase 3: Synthesis, days 10-12 -->
            <g>
              <line x1="461" y1="62" x2="461" y2="74" stroke="currentColor" stroke-width="1.5"/>
              <line x1="608" y1="62" x2="608" y2="74" stroke="currentColor" stroke-width="1"/>
              <text x="461" y="56" font-family="ui-monospace, Menlo, monospace" font-size="10" font-weight="600" fill="#8A5E18" letter-spacing="0.6">DAYS 10–12</text>
              <text x="461" y="92" font-family="'Playfair Display', serif" font-style="italic" font-size="16" fill="currentColor">Synthesis</text>
            </g>

            <!-- phase 4: Readout, day 14 -->
            <g>
              <line x1="608" y1="62" x2="608" y2="74" stroke="currentColor" stroke-width="1.5"/>
              <line x1="700" y1="58" x2="700" y2="78" stroke="#B8832A" stroke-width="2"/>
              <circle cx="700" cy="68" r="4" fill="#B8832A"/>
              <text x="608" y="56" font-family="ui-monospace, Menlo, monospace" font-size="10" font-weight="600" fill="#8A5E18" letter-spacing="0.6">DAY 14</text>
              <text x="608" y="92" font-family="'Playfair Display', serif" font-style="italic" font-size="16" fill="currentColor">Readout</text>
            </g>
          </svg>
          <figcaption class="diag-caption">
            Fixed-shape, fixed-length. Two weeks from kick-off to a
            decision-grade readout.
          </figcaption>
        </figure>

        <ol class="diag-phases">
          <li>
            <div class="phase-meta">Days 1–3</div>
            <div>
              <h3 class="phase-name">Kick-off and access.</h3>
              <p>
                Stakeholder map, data access, scope freeze. We name the
                business question we will answer in two weeks, and the
                three or four data pulls we need to answer it.
              </p>
            </div>
          </li>
          <li>
            <div class="phase-meta">Days 4–9</div>
            <div>
              <h3 class="phase-name">Investigation.</h3>
              <p>
                Interviews with the people closest to the operating
                reality. Hands-on data review. Surfacing the patterns
                that show up across both. We tell you what we are
                seeing as we see it — no surprise reveal at the end.
              </p>
            </div>
          </li>
          <li>
            <div class="phase-meta">Days 10–12</div>
            <div>
              <h3 class="phase-name">Synthesis.</h3>
              <p>
                What to ship, what to leave alone, what proof to commit.
                Sequenced backlog with effort and impact ranges. The
                exit criteria for whichever stage you actually need
                before you reach for stage three.
              </p>
            </div>
          </li>
          <li>
            <div class="phase-meta">Day 14</div>
            <div>
              <h3 class="phase-name">Readout.</h3>
              <p>
                Concrete recommendation, presented to the senior team.
                Decision-ready: enough detail to commit, scoped to
                avoid over-promising. If the case for an engagement
                is not there, we say so.
              </p>
            </div>
          </li>
        </ol>
      </section>

      <section class="aftermath">
        <h2 class="h2-section">After the diagnostic.</h2>
        <p>
          If the case is there, we agree on a sequenced engagement: a
          set of operating outcomes, the milestones that prove them,
          and the senior counterpart inside your organisation who
          inherits the system as we ship it. Engagement length is
          shaped by what is real to ship, not by a default contract
          length.
        </p>
        <p>
          The exit criterion is built in from week one. When the system
          is running and the counterpart is operating it, we leave.
        </p>
      </section>
    </div>

    <CTA />
  </article>
</BaseLayout>

<style>
  .prose-page { padding-top: clamp(40px, 6vh, 72px); }
  .section-label { margin-bottom: 18px; }
  .h1-page {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(32px, 4.5vw, 48px);
    line-height: 1.16;
    margin-bottom: 18px;
    letter-spacing: -0.01em;
    max-width: 22ch;
  }
  .lede {
    font-size: clamp(17px, 2vw, 20px);
    color: var(--text-secondary);
    line-height: 1.55;
    max-width: 56ch;
    margin-bottom: 56px;
  }
  .stages-diagram {
    margin: 8px 0 28px;
    padding: 24px 28px 18px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text-primary);
    max-width: 760px;
  }
  .stages-diagram svg { width: 100%; height: auto; display: block; }
  .stages-caption {
    margin-top: 14px;
    font-size: 13px;
    color: var(--text-muted);
    max-width: 60ch;
  }

  .stages {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
    margin-bottom: 64px;
  }
  @media (min-width: 720px) {
    .stages { grid-template-columns: repeat(3, 1fr); }
  }
  .stage {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 24px;
  }
  .stage-num {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--accent-text);
    font-weight: 600;
    letter-spacing: 0.1em;
    margin-bottom: 12px;
  }
  .stage-name {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 22px;
    color: var(--text-primary);
    margin-bottom: 10px;
    font-weight: 400;
  }
  .stage p { font-size: 15px; }

  .pmo-note {
    max-width: 720px;
    border-top: 1px solid var(--border);
    padding-top: 40px;
    margin-bottom: 64px;
  }
  .pmo-note h2 { margin-bottom: 18px; }
  .pmo-note p { max-width: 60ch; }

  .diag {
    border-top: 1px solid var(--border);
    padding-top: 40px;
    margin-bottom: 64px;
  }
  .diag .section-label { margin-bottom: 14px; }
  .diag h2 { margin-bottom: 18px; }
  .diag-head {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
    align-items: start;
    margin-bottom: 28px;
  }
  @media (min-width: 720px) {
    .diag-head {
      grid-template-columns: 1fr auto;
      gap: 36px;
    }
  }
  .diag-head h2 { margin-bottom: 14px; }
  .diag-head-stat {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    padding: 14px 22px;
    border-left: 3px solid var(--accent);
    background: var(--surface);
    border-radius: 0 4px 4px 0;
  }
  .diag-stat-num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(48px, 6vw, 64px);
    line-height: 1;
    color: var(--accent);
  }
  .diag-stat-label {
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 600;
  }
  .diag-lede {
    max-width: 60ch;
    margin-bottom: 0;
  }

  .approach-pullquote {
    padding: clamp(48px, 7vh, 88px) 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--surface-alt);
    margin: 56px 0;
  }
  .approach-pullquote blockquote {
    margin: 0 auto;
    padding: 0;
  }
  .approach-pullquote p {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(22px, 2.8vw, 32px);
    line-height: 1.3;
    color: var(--text-primary);
    margin: 0;
    max-width: 30ch;
  }
  .diag-timeline {
    margin: 0 0 36px;
    padding: 28px 28px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text-primary);
    max-width: 760px;
  }
  .diag-timeline svg {
    width: 100%;
    height: auto;
    display: block;
  }
  .diag-caption {
    margin-top: 14px;
    font-size: 13px;
    color: var(--text-muted);
    max-width: 56ch;
  }
  .diag-phases {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 16px;
    max-width: 760px;
  }
  .diag-phases li {
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: 18px;
    padding: 22px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
  }
  .phase-meta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent-text);
    font-weight: 600;
    letter-spacing: 0.06em;
    line-height: 1.5;
  }
  .phase-name {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 20px;
    color: var(--text-primary);
    margin-bottom: 8px;
  }
  .diag-phases p { font-size: 15px; max-width: 56ch; }

  .aftermath {
    border-top: 1px solid var(--border);
    padding-top: 40px;
    max-width: 720px;
  }
  .aftermath h2 { margin-bottom: 18px; }
  .aftermath p { max-width: 60ch; margin-bottom: 14px; }
</style>
