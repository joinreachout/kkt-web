---
import BaseLayout from '~/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — KKT"
  description="Book a diagnostic with KKT. Tallinn, EU."
>
  <article class="prose-page">
    <div class="container narrow">
      <div class="section-label">Contact</div>
      <h1 class="h1-page">Book a diagnostic.</h1>
      <p class="lede">
        Tell us what your business is trying to move — margin, cash,
        availability, customer value, or productivity — and we will tell you
        whether AI and PMO discipline can earn their place in it.
      </p>

      <div class="contact-block">
        <div class="contact-row">
          <div class="contact-label">Email</div>
          <a href="mailto:hello@kittykat.tech">hello@kittykat.tech</a>
        </div>

        <div class="contact-row">
          <div class="contact-label">Office</div>
          <div>Tallinn, Estonia</div>
        </div>

        <div class="contact-row">
          <div class="contact-label">Legal</div>
          <div>Kitty Kat Technologies OÜ</div>
        </div>
      </div>

      <p class="note">
        A two-week diagnostic is the cleanest way to start. Email above with a
        short note on your business and we will reply within two working days.
      </p>
    </div>
  </article>
</BaseLayout>

<style>
  .prose-page {
    padding-top: clamp(40px, 6vh, 72px);
    padding-bottom: clamp(56px, 9vh, 96px);
  }
  .narrow { max-width: 760px; }
  .section-label { margin-bottom: 18px; }
  .h1-page {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(32px, 4.5vw, 48px);
    line-height: 1.16;
    margin-bottom: 18px;
    letter-spacing: -0.01em;
  }
  .lede {
    font-size: clamp(17px, 2vw, 20px);
    color: var(--text-secondary);
    line-height: 1.55;
    max-width: 56ch;
    margin-bottom: 36px;
  }
  .contact-block {
    margin-bottom: 32px;
    border-top: 1px solid var(--border);
    padding-top: 24px;
  }
  .contact-row {
    display: grid;
    grid-template-columns: 120px 1fr;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
    font-size: 15px;
  }
  .contact-label {
    color: var(--text-muted);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    align-self: center;
  }
  .contact-row a { color: var(--text-primary); }
  .note {
    font-size: 14px;
    color: var(--text-muted);
    max-width: 56ch;
  }
</style>
