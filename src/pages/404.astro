---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CatMark from '~/components/CatMark.astro';
import GalagaGame from '~/components/GalagaGame.astro';
---

<BaseLayout
  title="404 — Not found — KKT"
  description="That page is not here. Have a Galaga while you find your way back."
  noindex={true}
>
  <article class="prose-page">
    <div class="container narrow">
      <div class="cat-wrap" aria-hidden="true">
        <CatMark size={64} />
      </div>
      <div class="section-label">404</div>
      <h1 class="h1-page">That page is not here.</h1>
      <p class="lede">
        Either it never was, or it moved. Either way — have a Galaga
        while you find your way back. The vendor decks won&rsquo;t
        ship themselves.
      </p>

      <div class="cta-row">
        <a href="/" class="btn-primary">Home</a>
        <a href="/case-studies/" class="btn-ghost">See our work</a>
      </div>
    </div>

    <div class="container narrow game-block">
      <GalagaGame />
    </div>
  </article>
</BaseLayout>

<style>
  .prose-page { padding-top: clamp(40px, 6vh, 72px); padding-bottom: clamp(56px, 9vh, 96px); }
  .narrow { max-width: 760px; }
  .cat-wrap {
    color: var(--text-primary);
    margin-bottom: 24px;
    opacity: 0.85;
  }
  .section-label { margin-bottom: 18px; color: var(--text-muted); }
  .h1-page {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.14;
    margin-bottom: 18px;
    letter-spacing: -0.01em;
    max-width: 18ch;
  }
  .lede {
    font-size: clamp(15px, 1.7vw, 18px);
    color: var(--text-secondary);
    line-height: 1.55;
    margin-bottom: 28px;
    max-width: 56ch;
  }
  .cta-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }
  .game-block {
    text-align: center;
    margin-top: 16px;
  }
</style>
