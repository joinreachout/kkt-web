---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTA from '~/components/CTA.astro';

// Smaller / earlier engagements — separate bucket from the marquee five.
// Listed for completeness, not heavyweight. Add new entries by dropping
// a logo into public/logos/ and appending here.
const smallerEngagements = [
  {
    name: 'Clubtek',
    region: 'Thailand',
    blurb: 'Premium audio, light, and video integration. Top-tier event and venue work.',
    logo: '/logos/clubtek.png',
  },
];

const cases = [
  {
    href: '/case-studies/alfa-oil',
    client: 'Alfa Oil',
    industry: 'Fuel retail',
    region: 'Kyrgyzstan',
    summary:
      'Optimus operating across 600+ stations. $500M revenue. Pricing, margin steering, station-level operations.',
    status: 'Featured',
    featured: true,
  },
  {
    href: '/case-studies/click-and-grow',
    client: 'Click & Grow',
    industry: 'B2C — smart indoor gardens',
    region: 'Eastern Europe / CIS',
    summary:
      'Customer analytics and ML segmentation to find where the high-value segments actually were, then act on them.',
    status: 'Delivered',
  },
  {
    href: '/case-studies/gte',
    client: 'GTE',
    industry: 'Industrial — compressors',
    region: 'EU',
    summary:
      'Reporting platform across finance and manufacturing, plus ML prototypes for compressor anomaly detection and energy optimisation.',
    status: 'Delivered',
  },
  {
    href: '/case-studies/kricon',
    client: 'Kricon',
    industry: 'International logistics',
    region: 'Cross-border',
    summary:
      'Operational visibility across the route network — reporting infrastructure plus anomaly-detection and clustering models for ops-level signals.',
    status: 'Delivered',
  },
  {
    href: '/case-studies/csc-telecom',
    client: 'CSC Telecom',
    industry: 'Telecom',
    region: 'Global',
    summary:
      'Customer and product analytics for a global Travel/Tourist SIM business. Each study shaped to land a specific decision rather than fill a report.',
    status: 'Delivered',
  },
];
---

<BaseLayout
  title="Case studies — KKT"
  description="Walkable investigations of what we shipped and what it moved."
  ogImage="/og/case-studies.png"
>
  <article class="prose-page">
    <div class="container">
      <div class="section-label">Case studies</div>
      <h1 class="h1-page">What we shipped, what it moved.</h1>
      <p class="lede">
        Walkable investigations — not vendor decks. Each case is the
        engagement as it actually ran: where it started, what shipped,
        what it changed in the business.
      </p>

      <ul class="case-list">
        {cases.map((c) => (
          <li>
            <a href={c.href} class={`case-card ${c.featured ? 'case-card-featured' : ''}`}>
              <div class="case-meta">
                <span class={`case-status ${c.featured ? 'is-featured' : ''}`}>{c.status}</span>
                <span class="case-sep">·</span>
                <span>{c.industry}</span>
                <span class="case-sep">·</span>
                <span>{c.region}</span>
              </div>
              <h2 class="case-client">{c.client}</h2>
              <p class="case-summary">{c.summary}</p>
              <span class="case-arrow">Read the case →</span>
            </a>
          </li>
        ))}
      </ul>

      {smallerEngagements.length > 0 && (
        <section class="smaller">
          <div class="section-label">Smaller engagements</div>
          <h2 class="h2-section">Earlier and adjacent work.</h2>
          <p class="smaller-lede">
            Listed for completeness — real shipped work, but not the
            marquee story KKT leads with on conversion-critical
            surfaces.
          </p>
          <ul class="smaller-grid">
            {smallerEngagements.map((s) => (
              <li class="smaller-card">
                <div class="smaller-logo">
                  <img src={s.logo} alt={`${s.name} logo`} loading="lazy" />
                </div>
                <div class="smaller-meta">
                  <div class="smaller-name">{s.name}</div>
                  <div class="smaller-region">{s.region}</div>
                </div>
                <p class="smaller-blurb">{s.blurb}</p>
              </li>
            ))}
          </ul>
        </section>
      )}
    </div>

    <CTA />
  </article>
</BaseLayout>

<style>
  .prose-page { padding-top: clamp(40px, 6vh, 72px); }
  .section-label { margin-bottom: 18px; }
  .h1-page {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(32px, 4.5vw, 48px);
    line-height: 1.16;
    margin-bottom: 18px;
    letter-spacing: -0.01em;
    max-width: 22ch;
  }
  .lede {
    font-size: clamp(17px, 2vw, 20px);
    color: var(--text-secondary);
    line-height: 1.55;
    max-width: 56ch;
    margin-bottom: 40px;
  }
  .case-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 16px;
  }
  .case-card {
    display: block;
    padding: 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    text-decoration: none;
    color: inherit;
    transition: border-color .18s ease;
  }
  .case-card:hover {
    border-color: var(--border-hover);
    text-decoration: none;
  }
  .case-card-featured {
    padding: 32px;
    border-top: 3px solid var(--accent);
  }
  .case-card-featured .case-client {
    font-size: 32px;
  }
  .case-status.is-featured {
    color: var(--accent);
  }

  .smaller {
    margin-top: 56px;
    padding-top: 40px;
    border-top: 1px solid var(--border);
  }
  .smaller .section-label { margin-bottom: 14px; }
  .smaller h2 { margin-bottom: 14px; max-width: 26ch; }
  .smaller-lede {
    max-width: 60ch;
    margin-bottom: 28px;
    color: var(--text-secondary);
  }
  .smaller-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 720px) {
    .smaller-grid { grid-template-columns: 1fr 1fr; }
  }
  .smaller-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 22px 24px;
    display: grid;
    grid-template-columns: 60px 1fr;
    column-gap: 16px;
    row-gap: 8px;
    align-items: start;
  }
  .smaller-logo {
    grid-row: 1 / span 2;
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .smaller-logo img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  .smaller-name {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 22px;
    color: var(--text-primary);
    line-height: 1.2;
  }
  .smaller-region {
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 600;
    margin-top: 2px;
  }
  .smaller-blurb {
    grid-column: 1 / -1;
    font-size: 14px;
    color: var(--text-secondary);
    margin: 0;
    max-width: 56ch;
  }
  .case-meta {
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 10px;
    letter-spacing: 0.04em;
  }
  .case-status {
    color: var(--accent-text);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .case-sep { margin: 0 6px; }
  .case-client {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 26px;
    color: var(--text-primary);
    margin-bottom: 10px;
    font-weight: 400;
  }
  .case-summary {
    margin-bottom: 14px;
    max-width: 60ch;
  }
  .case-arrow {
    font-size: 13px;
    color: var(--text-primary);
    font-weight: 500;
  }
</style>
