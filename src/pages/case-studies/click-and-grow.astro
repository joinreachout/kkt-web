---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTA from '~/components/CTA.astro';
import RelatedCases from '~/components/RelatedCases.astro';
---

<BaseLayout
  title="Click & Grow — Case study — KKT"
  description="Customer analytics and ML segmentation for a B2C smart-garden manufacturer."
>
  <article class="prose-page">
    <div class="container">
      <div class="section-label">Case study — Click & Grow</div>
      <h1 class="h1-page">Click & Grow — segmenting a B2C customer base for targeted growth.</h1>

      <section class="topline">
        <div class="topline-row">
          <div class="topline-label">Industry</div>
          <div>B2C — smart indoor gardens</div>
        </div>
        <div class="topline-row">
          <div class="topline-label">Region focus</div>
          <div>Eastern Europe / CIS</div>
        </div>
        <div class="topline-row">
          <div class="topline-label">Engagement</div>
          <div>Customer analytics + ML segmentation models</div>
        </div>
        <div class="topline-row">
          <div class="topline-label">Status</div>
          <div><span class="live-dot"></span> Delivered</div>
        </div>
      </section>

      <section class="prose-block">
        <p>
          Click & Grow asked us to lift sales in Eastern Europe and the CIS
          region. We ran a detailed customer analysis surfacing the
          behavioural patterns and preferences that mattered, then
          recommended targeted marketing activities and built machine-learning
          models for customer segmentation.
        </p>
        <p>
          Output: a clear picture of who the high-value segments actually
          were, plus the segmentation engine to act on it.
        </p>
      </section>

      <section class="stack">
        <div class="stack-label">Tech stack</div>
        <p>Scikit-learn · AzureML · Flask · Azure</p>
      </section>

      <p class="editorial-note">
        Walkable case in editorial. Phase 1.5.
      </p>
    </div>

    <RelatedCases current="click-and-grow" />

    <CTA />
  </article>
</BaseLayout>

<style>
  .prose-page { padding-top: clamp(40px, 6vh, 72px); }
  .section-label { margin-bottom: 18px; }
  .h1-page {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(30px, 4.2vw, 44px);
    line-height: 1.16;
    margin-bottom: 36px;
    letter-spacing: -0.01em;
    max-width: 26ch;
  }
  .topline {
    max-width: 720px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 24px 28px;
    margin-bottom: 32px;
  }
  .topline-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
    font-size: 15px;
  }
  .topline-row:last-child { border-bottom: none; }
  .topline-label {
    color: var(--text-muted);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    align-self: center;
  }
  .live-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #2A8A62;
    margin-right: 8px;
    vertical-align: middle;
  }
  .prose-block { max-width: 700px; margin-bottom: 32px; }
  .prose-block p { margin-bottom: 14px; max-width: 64ch; }
  .stack {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 18px 22px;
    max-width: 700px;
    margin-bottom: 32px;
  }
  .stack-label {
    font-size: 11px;
    color: var(--accent-text);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .stack p {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-secondary);
    margin: 0;
  }
  .editorial-note {
    font-size: 13px;
    color: var(--text-muted);
    font-style: italic;
    max-width: 60ch;
  }
</style>
