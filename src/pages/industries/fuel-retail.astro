---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CTA from '~/components/CTA.astro';
---

<BaseLayout
  title="Fuel retail — KKT"
  description="Optimus operates price, margin, and operations across fuel networks. Live at Alfa Oil — 600+ stations."
>
  <article class="prose-page">
    <div class="container">
      <div class="section-label">Industries — Fuel retail</div>
      <h1 class="h1-page">For fuel networks.</h1>
      <p class="lede">
        Optimus is our operating system for fuel retail — pricing, margin
        steering, and station-level operations under one roof. Live in
        production; not a pilot.
      </p>

      <section class="proof-strip">
        <div class="proof-card">
          <div class="proof-num">600+</div>
          <div class="proof-label">stations operating Optimus</div>
        </div>
        <div class="proof-card">
          <div class="proof-num">$500M</div>
          <div class="proof-label">network revenue at Alfa Oil</div>
        </div>
        <div class="proof-card">
          <div class="proof-num">11</div>
          <div class="proof-label">fuel types, multi-region</div>
        </div>
      </section>

      <section class="cta-row">
        <a href="/solutions/optimus" class="btn-primary">See Optimus →</a>
        <a href="/case-studies/alfa-oil" class="btn-ghost">Read the Alfa Oil case</a>
      </section>
    </div>

    <CTA
      heading="Fuel network diagnostic, two weeks."
      body="A scoped look at where Optimus applies to your network — pricing posture, margin posture, station-level operations, and what shipping looks like."
    />
  </article>
</BaseLayout>

<style>
  .prose-page { padding-top: clamp(40px, 6vh, 72px); }
  .section-label { margin-bottom: 18px; }
  .h1-page {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(32px, 4.5vw, 48px);
    line-height: 1.16;
    margin-bottom: 18px;
    letter-spacing: -0.01em;
    max-width: 22ch;
  }
  .lede {
    font-size: clamp(17px, 2vw, 20px);
    color: var(--text-secondary);
    line-height: 1.55;
    max-width: 60ch;
    margin-bottom: 40px;
  }
  .proof-strip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 16px;
    margin-bottom: 36px;
    max-width: 820px;
  }
  .proof-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 20px 24px;
  }
  .proof-num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 32px;
    color: var(--text-primary);
    margin-bottom: 4px;
    line-height: 1;
  }
  .proof-label {
    font-size: 13px;
    color: var(--text-secondary);
  }
  .cta-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }
</style>
