---
import BaseLayout from '~/layouts/BaseLayout.astro';
import GalagaGame from '~/components/GalagaGame.astro';
---

<BaseLayout
  title="Decks down — KKT"
  description="An easter-egg arcade game. AI that ships, not slides — and you can shoot them."
  noindex={true}
>
  <article class="game-page">
    <div class="container narrow">
      <div class="section-label">Easter egg</div>
      <h1 class="h1-page">Decks down.</h1>
      <p class="lede">
        Shoot down vendor decks before they reach the bottom. Each
        deck is a buzzword we&rsquo;d push back on at a diagnostic.
      </p>

      <GalagaGame />
    </div>
  </article>
</BaseLayout>

<style>
  .game-page { padding-top: clamp(40px, 6vh, 72px); padding-bottom: clamp(56px, 9vh, 96px); }
  .narrow { max-width: 760px; text-align: center; }
  .narrow > div, .narrow > p, .narrow > h1 { text-align: left; }
  .section-label { margin-bottom: 18px; }
  .h1-page {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.14;
    margin-bottom: 14px;
    letter-spacing: -0.01em;
  }
  .lede {
    font-size: clamp(15px, 1.7vw, 18px);
    color: var(--text-secondary);
    line-height: 1.55;
    margin-bottom: 32px;
    max-width: 56ch;
  }
</style>
